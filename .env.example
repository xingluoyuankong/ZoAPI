# Твой Zo API ключ (Settings > Advanced > Access Tokens)
ZO_API_KEY=zo_sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Базовый URL Zo API (менять обычно не надо)
ZO_BASE_URL=https://api.zo.computer

# Модель Zo по умолчанию (если Claude Code не задаст явно)
# Список: GET https://api.zo.computer/models/available
ZO_DEFAULT_MODEL=anthropic:claude-opus-4-7

# Порт локального прокси
PROXY_PORT=17878

# Мэппинг "anthropic-имя -> zo model_name".
# Claude Code просит модели вроде "claude-sonnet-4-5", "claude-opus-4-...".
# JSON-объект. Ключи — подстроки, которые ищем в model из запроса.
MODEL_MAP={"opus":"anthropic:claude-opus-4-7","sonnet":"anthropic:claude-sonnet-4-5","haiku":"anthropic:claude-haiku-4-5-20251001"}

# Persona (опционально). Список: GET /personas/available
ZO_PERSONA_ID=

# Логирование: DEBUG / INFO / WARNING
LOG_LEVEL=INFO
